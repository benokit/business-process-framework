[
    {
        "id": "entity-transaction-middleware-base",
        "kind": "executable",
        "data": [
            {
                "inputMap": {
                    "program": "#.input.next",
                    "programInput": "#.input.input"
                },
                "service": "transaction", "method": "executeInTransaction"
            }
        ]
    },
    {
        "id": "entity-transaction-middleware-create",
        "kind": "middleware/entity-service/create/root-entity-class",
        "data": {
