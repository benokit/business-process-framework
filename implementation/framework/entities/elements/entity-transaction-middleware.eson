        }
    },
    {
        "id": "entity-transaction-middleware-update",
        "kind": "middleware/entity-service/update/root-entity-class",
        "data": {
            "ordering": 50,
            "implementation": [{ "call": "entity-transaction-middleware-base" }]
        }
    },
    {
        "id": "entity-transaction-middleware-delete",
        "kind": "middleware/entity-service/delete/root-entity-class",
        "data": {
            "ordering": 50,
            "implementation": [{ "call": "entity-transaction-middleware-base" }]
        }
    },
    {
        "id": "entity-transaction-middleware-transition",
        "kind": "middleware/entity-service/transition/root-entity-class",
