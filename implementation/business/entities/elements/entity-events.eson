[
    {
        "id": "entity-events-broker",
        "kind": "message-broker",
        "data": {
            "service": "messaging-nats",
            "url": "nats://localhost:4222"
        }
    },
    {
        "id": "entity-events",
        "data": {
            "broker": "entity-events-broker",
            "topology": "topic",
            "name": "entity-events",
            "publisher": {
                "transactionalOutbox": true,
                "retry": { "attempts": 5, "backoff": 500 }
            }
        }
    },
    {
        "kind": "schema",
        "id": "entity-event-message",
        "data":{
            "!eventType": "string",
            "!entityType": "string",
            "!businessKey": "string",
            "!revision": "number"
        }
    },
    {
        "kind": "schema",
        "id": "entity-event-publisher-input",
        "data":{
            "!entityType": "string",
            "!record": "@entity-record",
            "!eventType": "string",
            "correlation": "string"
        }
    },
    {
        "id": "entity-event-publisher-interface",
        "data": {
            "publish": {
                "input": "@entity-event-publisher-input",
                "output": {}
            }
        }
    },
    {
        "id": "entity-event-publisher-implementation",
        "data": {
            "publish": [
                {
                    "name": "envelope",
                    "set": {
                        "messageId": { "$join": { "_strings": ["#.input.record.id", "-", "#.input.record.revision", "-", "#.input.eventType"] } },
                        "timestampUTC": "#.input.record.timestampUtc",
                        "group": "#.input.record.businessKey",
                        "correlation": { "$coalesce": ["#.input.correlation", ""] },
                        "message": {
                            "eventType": "#.input.eventType",
                            "entityType": "#.input.entityType",
                            "businessKey": "#.input.record.businessKey",
                            "revision": "#.input.record.revision"
                        }
                    }
                },
                {
                    "execute": {
                        "publish": {
                            "channel": "entity-events",
                            "envelope": "#.envelope"
                        }
                    }
                }
            ]
        }
    },
    {
        "kind": "service",
        "id": "entity-event-publisher",
        "data": {
            "interface": "entity-event-publisher-interface",
            "implementation": "entity-event-publisher-implementation"
        }
    }
]
