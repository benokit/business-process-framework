[
    {
        "type": "data",
        "id": "messaging-service-implementation",
        "data": {
            "publish": [
                { "name": "channel", "getData": "#.input.channel" },
                { "name": "broker", "getData": "#.channel.data.broker" },
                {
                    "if": "#.channel.data.publisher.transactionalOutbox",
                    "then": {
                        "inputMap": { "channel": "#.input.channel", "envelope": "#.input.envelope" },
                        "service": { "id": "transactional-outbox", "method": "put" }
                    },
                    "else": {
                        "execute": { "service": { "id": "#.broker.data.service", "method": "publish" } },
                        "inputMap": { "channel": "#.channel.data", "broker": "#.broker.data", "envelope": "#.input.envelope" }
                    }
                }
            ],
            "startConsumers": [
                {
                    "if": "#.input.channel",
                    "then": [
                        { "name": "channel", "getData": "#.input.channel" },
                        { "name": "broker", "getData": "#.channel.data.broker" },
                        { "name": "allConsumers", "getDataOfKind": "message-consumer" },
                        {
                            "name": "channelConsumers",
                            "set": {
                                "$let": { "channelId": "#.channel.id" },
                                "$filter": {
                                    "_predicate": { "$eq": ["#.data.channel", "@channelId"] },
                                    "_collection": "#.allConsumers.items"
                                }
                            }
                        },
                        {
                            "name": "consumers",
                            "set": {
                                "$let": {
                                    "channelData": "#.channel.data",
                                    "brokerData": "#.broker.data",
                                    "brokerId": "#.broker.data.service"
                                },
                                "$map": {
                                    "_fn": { "channel": "@channelData", "broker": "@brokerData", "brokerId": "@brokerId", "consumer": "#.data" },
                                    "_over": "#.channelConsumers"
                                }
                            }
                        },
                        {
                            "forEach": [
                                {
                                    "execute": { "service": { "id": "#.input.brokerId", "method": "consume" } },
                                    "inputMap": { "channel": "#.input.channel", "broker": "#.input.broker", "consumer": "#.input.consumer" }
                                }
                            ],
                            "inputMap": "#.consumers"
                        }
                    ],
                    "else": [
                        { "name": "allChannels", "getDataOfKind": "message-channel" },
                        {
                            "forEach": [
                                {
                                    "service": { "id": "messaging-service", "method": "startConsumers" },
                                    "inputMap": { "channel": "#.input.id" }
                                }
                            ],
                            "inputMap": "#.allChannels.items"
                        }
                    ]
                }
            ],
            "stopConsumers": [
                {
                    "if": "#.input.channel",
                    "then": [
                        { "name": "channel", "getData": "#.input.channel" },
                        { "name": "broker", "getData": "#.channel.data.broker" },
                        {
                            "execute": { "service": { "id": "#.broker.data.service", "method": "stopConsuming" } },
                            "inputMap": { "channel": "#.channel.data", "broker": "#.broker.data" } 
                        }
                    ],
                    "else": [
                        { "name": "allChannels", "getDataOfKind": "message-channel" },
                        {
                            "forEach": [
                                {
                                    "service": { "id": "messaging-service", "method": "stopConsumers" },
                                    "inputMap": { "channel": "#.input.id" }
                                }
                            ],
                            "inputMap": "#.allChannels.items"
                        }
                    ]
                }
            ]
        }
    },
    {
        "type": "service",
        "id": "messaging-service",
        "interface": "messaging-service-interface",
        "implementation": "messaging-service-implementation"
    },
    {
        "type": "data",
        "id": "publish-node-template",
        "kind": "execution-node-template",
        "data": {
            "keyword": "publish",
            "implementation": [
                { "name": "id", "service": { "id": "random", "method": "guid" } },
                {
                    "name": "envelope",
                    "set": {
                        "messageId":    { "$coalesce": ["#.node.publish.envelope.messageId",    "#.id.value"] },
                        "timestampUTC": { "$coalesce": ["#.node.publish.envelope.timestampUTC", "#._ctx.timestampUTC"] },
                        "group":        { "$coalesce": ["#.node.publish.envelope.group",        "#._ctx.group"] },
                        "correlation":  { "$coalesce": ["#.node.publish.envelope.correlation",  "#._ctx.correlation", ""] },
                        "message":      "#.node.publish.envelope.message"
                    }
                },
                {
                    "inputMap": { "channel": "#.node.publish.channel", "envelope": "#.envelope" },
                    "service": { "id": "messaging-service", "method": "publish" }
                }
            ]
        }
    }
]
