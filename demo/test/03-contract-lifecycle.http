@baseUrl = http://localhost:3000

# =============================================================================
# Contract lifecycle — happy path
#
# Prerequisites: run 01-users.http and 02-parties.http first so that
# "acme" and "globocorp" exist and are in "verified" state.
# =============================================================================

# --- Step 1: create + submit in one call via the workflow service ------------

### Create and submit contract (draft → pending-approval)
# @name createAndSubmit
POST {{baseUrl}}/services/contract-workflow/createAndSubmit
Content-Type: application/json

{
    "businessKey": "CNT-001",
    "title": "Supply Agreement 2026",
    "sellerPartyKey": "acme",
    "buyerPartyKey": "globocorp",
    "value": 50000,
    "currency": "USD",
    "startDate": "2026-04-01",
    "endDate": "2027-03-31",
    "terms": "Net 30 payment terms. Delivery within 14 days."
}

# --- Step 2: approve via workflow service (validates party states) -----------

### Approve contract — workflow checks both parties are verified
# @name approveContract
POST {{baseUrl}}/services/contract-workflow/approve
Content-Type: application/json

{
    "businessKey": "CNT-001"
}

# --- Step 3: activate -------------------------------------------------------

### Activate contract (approved → active)
# @name activateContract
POST {{baseUrl}}/entities/contract/CNT-001/transitions/activate

### Read the active contract
GET {{baseUrl}}/entities/contract/CNT-001

# --- Step 4a: expire (end of life) ------------------------------------------

### Expire contract (active → expired)
POST {{baseUrl}}/entities/contract/CNT-001/transitions/expire

# --- Alternative step 4b: terminate early -----------------------------------
# Uncomment to use instead of expire (requires contract in "active" state)

# POST {{baseUrl}}/entities/contract/CNT-001/transitions/terminate

# --- Data versioning: amend contract terms ----------------------------------
# Contracts support versioning — amend records a new data version with an
# optional validFrom date while preserving the full history.

### Amend contract value (new version, takes effect 2026-07-01)
PUT {{baseUrl}}/entities/contract/CNT-001/amend
Content-Type: application/json
If-Match: {{activateContract.response.headers.etag}}

{
    "data": {
        "title": "Supply Agreement 2026 (Amended)",
        "sellerPartyKey": "acme",
        "buyerPartyKey": "globocorp",
        "value": 75000,
        "currency": "USD",
        "startDate": "2026-04-01",
        "endDate": "2027-03-31",
        "terms": "Net 30 payment terms. Delivery within 14 days. Volume discount applied."
    },
    "validFrom": "2026-07-01"
}

# --- Reject path ------------------------------------------------------------
# A separate contract that goes through rejection and re-submission.

### Create second contract
# @name createCnt002
POST {{baseUrl}}/entities/contract/
Content-Type: application/json

{
    "businessKey": "CNT-002",
    "data": {
        "title": "Consulting Agreement",
        "sellerPartyKey": "acme",
        "buyerPartyKey": "globocorp",
        "value": 12000,
        "currency": "EUR",
        "startDate": "2026-05-01",
        "endDate": "2026-10-31"
    }
}

### Submit CNT-002 manually (draft → pending-approval)
POST {{baseUrl}}/entities/contract/CNT-002/transitions/submit

### Reject CNT-002 (pending-approval → rejected)
POST {{baseUrl}}/entities/contract/CNT-002/transitions/reject

### Re-submit after rejection (rejected → pending-approval)
POST {{baseUrl}}/entities/contract/CNT-002/transitions/submit

### Approve CNT-002 via workflow
POST {{baseUrl}}/services/contract-workflow/approve
Content-Type: application/json

{
    "businessKey": "CNT-002"
}
