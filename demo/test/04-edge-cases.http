@baseUrl = http://localhost:3000

# =============================================================================
# Edge cases and error scenarios
# Each request below is expected to return an error.
# =============================================================================

# --- Guard: contract value must be > 0 --------------------------------------

### Create contract with zero value — rejected by contract-value-guard
POST {{baseUrl}}/entities/contract
Content-Type: application/json

{
    "businessKey": "BAD-VALUE",
    "data": {
        "title": "Zero-value contract",
        "sellerPartyKey": "acme",
        "buyerPartyKey": "globocorp",
        "value": 0,
        "currency": "USD",
        "startDate": "2026-04-01",
        "endDate": "2027-03-31"
    }
}

### Update contract to negative value — rejected by contract-value-guard
PUT {{baseUrl}}/entities/contract/CNT-001
Content-Type: application/json
If-Match: "1"

{
    "data": {
        "title": "Supply Agreement 2026",
        "sellerPartyKey": "acme",
        "buyerPartyKey": "globocorp",
        "value": -500,
        "currency": "USD",
        "startDate": "2026-04-01",
        "endDate": "2027-03-31"
    }
}

# --- Guard: seller and buyer must differ ------------------------------------

### Create contract where seller == buyer — rejected by contract-parties-guard
POST {{baseUrl}}/entities/contract
Content-Type: application/json

{
    "businessKey": "BAD-PARTIES",
    "data": {
        "title": "Self-deal",
        "sellerPartyKey": "acme",
        "buyerPartyKey": "acme",
        "value": 1000,
        "currency": "USD",
        "startDate": "2026-04-01",
        "endDate": "2027-03-31"
    }
}

# --- Workflow: approve with unverified party --------------------------------
# Requires a contract whose parties include at least one prospect/blacklisted party.

### Create a party that is NOT verified
POST {{baseUrl}}/entities/party
Content-Type: application/json

{
    "businessKey": "unverified-co",
    "data": {
        "partyType": "company",
        "name": "Unverified Co"
    }
}

### Create and submit contract with unverified buyer
POST {{baseUrl}}/services/contract-workflow/createAndSubmit
Content-Type: application/json

{
    "businessKey": "CNT-UNVERIFIED",
    "title": "Risky Deal",
    "sellerPartyKey": "acme",
    "buyerPartyKey": "unverified-co",
    "value": 5000,
    "currency": "USD",
    "startDate": "2026-04-01",
    "endDate": "2026-12-31"
}

### Approve — should throw "buyer party is not verified"
POST {{baseUrl}}/services/contract-workflow/approve
Content-Type: application/json

{
    "businessKey": "CNT-UNVERIFIED"
}

# --- Optimistic concurrency: stale revision ---------------------------------

### Update with wrong revision — should fail
PUT {{baseUrl}}/entities/user/admin-001
Content-Type: application/json
If-Match: "999"

{
    "data": {
        "email": "alice@company.com",
        "firstName": "Alice",
        "lastName": "Smith",
        "role": "admin"
    }
}

# --- Invalid state transition -----------------------------------------------

### Try to activate a draft contract (skipping submit/approve) — should fail
POST {{baseUrl}}/entities/contract/CNT-001/transitions/activate

# --- Not found --------------------------------------------------------------

### Read a non-existent entity
GET {{baseUrl}}/entities/contract/DOES-NOT-EXIST

# --- Missing required fields ------------------------------------------------

### Create contract without required fields
POST {{baseUrl}}/entities/contract
Content-Type: application/json

{
    "businessKey": "MISSING-FIELDS",
    "data": {
        "title": "Incomplete"
    }
}
